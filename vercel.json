{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "kaathabook.html",
          "customer.html",
          "utils.js",
          "manifest.json",
          "sw.js",
          "KaathaBook — Digital Udhaar Store_files/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(css2|KaathaBook%20—%20Digital%20Udhaar%20Store_files/.*|utils.js|manifest.json|sw.js|favicon.ico)",
      "dest": "/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
